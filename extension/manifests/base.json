{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "short_name": "Ravyn",
  "description": "__MSG_extensionDescription__",
  "version": "0.2.0",
  "default_locale": "en",
  "icons": {
    "16": "icons/ravyn-16.png",
    "32": "icons/ravyn-32.png",
    "48": "icons/ravyn-48.png",
    "96": "icons/ravyn-96.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Ravyn",
    "default_icon": {
      "16": "icons/ravyn-16.png",
      "32": "icons/ravyn-32.png"
    }
  },
  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },
  "permissions": [
    "activeTab",
    "downloads",
    "menus",
    "nativeMessaging",
    "notifications",
    "scripting",
    "storage",
    "tabs"
  ],
  "optional_permissions": ["cookies", "webRequest"],
  "optional_host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": false
    }
  ],
  "commands": {
    "open-sidebar": {
      "suggested_key": { "default": "Alt+Shift+R" },
      "description": "Open the Ravyn resource sidebar"
    },
    "download-current-page": {
      "suggested_key": { "default": "Alt+Shift+D" },
      "description": "Send the current page to Ravyn"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
  }
}
