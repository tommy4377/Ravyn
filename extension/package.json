{
  "name": "ravyn-firefox-extension",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Firefox integration for the Ravyn download manager",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "node scripts/build-firefox.mjs",
    "build:source": "node scripts/package-source.mjs",
    "package": "npm run build && node scripts/package-firefox.mjs",
    "dev": "node scripts/build-firefox.mjs --watch",
    "run": "npm run build && web-ext run --source-dir dist/firefox",
    "lint": "npm run typecheck && npm run lint:eslint && npm run lint:python && npm run lint:webext",
    "lint:eslint": "eslint src scripts test-pages/server.mjs",
    "lint:webext": "npm run build && web-ext lint --source-dir dist/firefox --warnings-as-errors",
    "format": "prettier --write \"{src,scripts,manifests,static,test-pages}/**/*.{ts,mjs,json,css,html}\" \"*.md\"",
    "format:check": "prettier --check \"{src,scripts,manifests,static,test-pages}/**/*.{ts,mjs,json,css,html}\" \"*.md\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "npm run format:check && npm run lint && npm test && npm run package && npm run build:source",
    "lint:python": "python3 -m py_compile scripts/deterministic-zip.py",
    "package:verify": "node scripts/verify-packages.mjs",
    "test:fixtures": "node test-pages/server.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/node": "^24.0.15",
    "esbuild": "^0.25.6",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4",
    "web-ext": "^10.5.0"
  }
}
