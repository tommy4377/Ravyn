{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "setup-capability",
  "description": "Native permissions required by the trusted first-run setup window.",
  "windows": [
    "setup"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "allow-backend-info",
    "allow-setup-installation-info",
    "allow-apply-windows-integration",
    "allow-finish-setup-handoff",
    "allow-restart-application"
  ]
}
