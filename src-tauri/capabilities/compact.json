{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "compact-capability",
  "description": "Minimal native permissions for the compact download progress window.",
  "windows": [
    "compact"
  ],
  "permissions": [
    "core:default",
    "mcp-bridge:default",
    "core:window:allow-close",
    "core:window:allow-hide",
    "allow-backend-info",
    "allow-focus-main-window",
    "allow-desktop-appearance"
  ]
}
