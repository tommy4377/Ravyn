{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Minimal native permissions required by the Ravyn main window.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "mcp-bridge:default",
    "allow-backend-info",
    "allow-main-window-ready",
    "allow-app-update-status",
    "allow-check-app-update",
    "allow-repair-application",
    "allow-install-app-update-now",
    "allow-cancel-app-update",
    "allow-desktop-appearance",
    "allow-open-native-path",
    "allow-reveal-native-path",
    "allow-browser-integration-status",
    "allow-repair-browser-integration",
    "allow-remove-browser-integration",
    "allow-take-browser-action",
    "allow-prompt-torrent-default-app",
    "allow-notify-native",
    "allow-open-compact-window",
    "allow-focus-main-window",
    "notification:default"
  ]
}
